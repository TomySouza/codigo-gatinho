          <p><i class="bi bi-envelope"></i> contato@adopet.org.br</p>
          <p><i class="bi bi-telephone"></i> (11) 99999-9999</p>
        </div>
      </div>
      <hr>
      <p class="text-light mb-0">© 2025 ONG AdoPet — Todos os direitos reservados.</p>
    </div>
  </footer>
</body>
</html>
